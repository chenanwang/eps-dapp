// Prisma schema for EPS.
// Real domain models are introduced in later phases (P1+). For P0 this holds a
// single placeholder `Health` model so `prisma migrate dev` has something to apply.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Placeholder model so the initial migration is non-empty.
/// Replaced/extended by real domain models in P1.
model Health {
  id        String   @id @default(uuid())
  status    String   @default("ok")
  createdAt DateTime @default(now())
}

/// A Clerk organization (the billable tenant). `clerkOrgId` is the verified
/// org id from the Clerk session token ГѓВўГ‚ВЂГ‚В” never accepted from the client.
model Organization {
  id              String           @id @default(uuid())
  clerkOrgId      String           @unique
  name            String
  /// Service-owner contact address. Used as the "To" for the first-access alert
  /// email when a recipient first opens a notice (T-402). Nullable: not every
  /// org has supplied one yet; the alert is skipped when absent.
  ownerEmail      String?
  createdAt       DateTime         @default(now())
  subscriptions   Subscription[]
  serviceRequests ServiceRequest[]
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

/// A subscription period for an organization. `usageCount` is the quota meter
/// for the current period; it resets on rollover (see P1/T-105).
model Subscription {
  id           String             @id @default(uuid())
  orgId        String
  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tierId       String
  status       SubscriptionStatus
  periodStart  DateTime
  periodEnd    DateTime
  usageCount   Int                @default(0)

  @@index([orgId])
}

/// Stripe webhook idempotency ledger. A row exists once an event id has been
/// processed, so replayed events become no-ops (see P1/T-104).
model WebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  processedAt DateTime @default(now())
}

/// Lifecycle of a service request as it moves from intake through chain delivery.
///  - STAGED      ГѓВўГ‚ВЂГ‚В” created at intake (T-203), quota decremented, awaiting fulfilment.
///  - IN_PROGRESS ГѓВўГ‚ВЂГ‚В” the worker has picked it up and is delivering on-chain (P3).
///  - CONFIRMED   ГѓВўГ‚ВЂГ‚В” transaction finalized and re-read verified (P3).
///  - FAILED      ГѓВўГ‚ВЂГ‚В” delivery failed; quota restored, surfaced on the dashboard (P3).
enum ServiceStatus {
  STAGED
  IN_PROGRESS
  CONFIRMED
  FAILED
}

/// A single service-of-process request. Created at intake (P2/T-203) in the
/// STAGED state after the org's quota is decremented; the fulfilment worker
/// (P3) advances it through delivery and stamps the on-chain proof fields
/// (`txSignature`, `slot`, `blockTime`). `recipientWallet` is a validated,
/// on-curve Solana address (see `lib/solana/validate-address.ts`). `attestedAt`
/// records when the filer attested to the accuracy of the caption. The caption
/// fields are confidential legal-filing metadata ГѓВўГ‚ВЂГ‚В” never logged (hard rule #3).
model ServiceRequest {
  id              String        @id @default(uuid())
  /// Verified Clerk user id of the filer who staged this request. This is the
  /// primary owner scope: the dashboard lists a user's own requests by `userId`,
  /// so a brand-new user with no organization can still file and see their work
  /// (issue #112). Nullable only because rows staged before this column existed
  /// have no value; all new intakes stamp it.
  userId          String?
  /// Owning organization (the billable tenant), when the filer has an active
  /// Clerk org. OPTIONAL: a user with no active organization files unscoped to
  /// any org, so quota metering (which keys on the org's subscription) is simply
  /// skipped for them. Org-scoped intakes still connect and meter as before.
  orgId           String?
  organization    Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  caseCaption     String
  plaintiffName   String
  defendantName   String
  recipientWallet String
  courtOrderFlag  Boolean       @default(false)
  attestedAt      DateTime
  noticeToken     String?       @unique
  /// SHA-256 (hex) of the served document, computed at intake (T-204). The
  /// worker encodes it into the on-chain memo (`${sha256}|${noticeToken}|${id}`)
  /// and re-reads it post-confirm to verify the delivery (T-305).
  documentSha256  String?
  status          ServiceStatus @default(STAGED)
  txSignature     String?
  slot            BigInt?
  blockTime       DateTime?
  /// Human-readable reason a delivery terminally failed (send error, memo
  /// mismatch, timeout). Surfaced on the dashboard's FAILED rows (T-306). Holds
  /// only error/diagnostic text ГѓВўГ‚ВЂГ‚В” never document or caption bytes (hard rule #3).
  failureReason   String?
  createdAt       DateTime      @default(now())


  // ENS fields (Phase 2)
  ensDisplayName     String?   // e.g. "defendant.eth"
  agentENSName       String?   // e.g. "eps-agent.eth"

  // Hedera fields (Phase 3)
  hcsTopicId         String?
  hcsSequenceNumber  Int?
  hcsConsensusTime   String?
  hcsTxId            String?
  hcsMirrorUrl       String?
  htsTokenId         String?
  htsSerialNumber    Int?
  htsTxId            String?
  htsMirrorUrl       String?

    /// First-access records (T-402). At most one row exists per notice (the
  /// `noticeId` unique constraint makes recording the first view idempotent).
  access          NoticeAccess?
  /// Certificate "First Viewed" addendum (T-402), written alongside the first
  /// access so the certificate (T-403) can regenerate with the view recorded.
  addendum        CertificateAddendum?
  /// The generated certificate PDF (T-403), stored once and served on demand.
  certificatePdf  CertificatePdf?


  @@index([orgId])
  // The dashboard lists a user's own requests newest-first (issue #112) вЂ” index
  // the owner scope for that hot path.
  @@index([userId])
  // The worker claims rows by status (STAGED/IN_PROGRESS), and the dashboard
  // lists an org's requests newest-first ГѓВўГ‚ВЂГ‚В” index both for those hot paths (T107).
  @@index([status])
  @@index([createdAt])
  @@index([orgId, status, createdAt])
}

/// One row per notice, recorded the first time a recipient opens `/n/<token>`
/// (T-402). The `noticeId` unique constraint enforces first-access-only
/// semantics: `recordFirstAccess` inserts once and is a no-op thereafter.
/// `ip`/`userAgent` are request metadata for the proof-of-access trail; the
/// certificate addendum stores only a MASKED ip (last octet dropped).
model NoticeAccess {
  id         String         @id @default(uuid())
  noticeId   String         @unique
  notice     ServiceRequest @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  ip         String
  userAgent  String
  accessedAt DateTime       @default(now())
}

/// "First Viewed" addendum appended to a notice's certificate (T-402). Written
/// in the SAME transaction as the first {@link NoticeAccess} row. `viewerIp` is
/// MASKED (last octet ГѓВўГ‚В†Г‚В’ `x`) ГѓВўГ‚ВЂГ‚В” the certificate is a court-facing artefact and
/// need not expose a full address.
model CertificateAddendum {
  id        String         @id @default(uuid())
  noticeId  String         @unique
  notice    ServiceRequest @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  /// When the recipient first viewed the notice (UTC).
  viewedAt  DateTime
  /// Masked recipient IP (last octet dropped).
  viewerIp  String
  createdAt DateTime       @default(now())
}

/// Generated certificate PDF for a served notice (T-403). One row per notice
/// (the `noticeId` unique constraint), generated on first download and reused
/// thereafter. The PDF bytes are stored base64-encoded in `pdfBase64`. The
/// certificate carries only court-facing proof fields (caption, file hash,
/// on-chain proof, first-view record) ГѓВўГ‚ВЂГ‚В” never document or caption bytes beyond
/// what the cover sheet already exposes (hard rule #3).
model CertificatePdf {
  id          String         @id @default(uuid())
  noticeId    String         @unique
  notice      ServiceRequest @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  /// Base64-encoded PDF bytes.
  pdfBase64   String
  generatedAt DateTime       @default(now())
}

/// Append-only audit trail. Every state transition writes one row in the SAME
/// DB transaction as the change it records (CLAUDE.md hard rule #5). `actorId`
/// is the verified Clerk user id that performed the action; `targetId` is the
/// subject of the action (e.g. the granted org); `metadata` carries
/// action-specific detail.
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  actorId   String
  targetId  String
  metadata  Json?
  createdAt DateTime @default(now())
}
